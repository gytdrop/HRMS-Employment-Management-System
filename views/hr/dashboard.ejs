<%- include('../layouts/header') %>

<div style="margin-bottom: 2rem;">
  <h1>Employee Management</h1>
  <p>Onboard new staff members and manage roles and permissions</p>
</div>

<% if (error) { %>
  <script>window.addEventListener('DOMContentLoaded', function () { showToast(<%- JSON.stringify(error) %>, 'error'); });</script>
<% } %>

<% if (success) { %>
  <script>window.addEventListener('DOMContentLoaded', function () { showToast(<%- JSON.stringify(success) %>, 'success'); });</script>
<% } %>

<div style="display: grid; grid-template-columns: 320px 1fr; gap: 2rem; align-items: start;">
  <!-- Onboarding Form Sidebar -->
  <div class="card">
    <h3 style="margin-bottom: 1.25rem; display: flex; align-items: center; gap: 6px;">
      <span class="material-symbols-outlined" style="color: var(--primary);">person_add</span>
      Onboard Employee
    </h3>
    <form action="/hr/create" method="POST">
      <div class="form-group">
        <label class="form-label" for="firstName">First Name</label>
        <input type="text" id="firstName" name="firstName" class="form-input" placeholder="e.g. John" required />
      </div>

      <div class="form-group">
        <label class="form-label" for="lastName">Last Name</label>
        <input type="text" id="lastName" name="lastName" class="form-input" placeholder="e.g. Doe" required />
      </div>

      <div class="form-group">
        <label class="form-label" for="email">Email Address</label>
        <input type="email" id="email" name="email" class="form-input" placeholder="e.g. john.doe@company.com" required />
      </div>

      <div class="form-group" style="margin-bottom: 1.5rem;">
        <label class="form-label" for="role">System Role</label>
        <select id="role" name="role" class="form-input" style="appearance: auto;" required>
          <option value="employee">Employee (Read-Only)</option>
          <option value="admin">Admin / HR Officer</option>
        </select>
      </div>

      <button type="submit" class="btn btn-primary" style="width: 100%; font-weight: 600;">
        Register & Generate ID
      </button>
    </form>
  </div>

  <!-- Employee Directory -->
  <div class="card">
    <h3 style="margin-bottom: 1.25rem;">Employee Directory</h3>
    
    <% if (employees && employees.length > 0) { %>
      <div class="table-container">
        <table>
          <thead>
            <tr>
              <th>Name</th>
              <th>Login ID</th>
              <th>Email</th>
              <th>Role</th>
              <th>Joined</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% employees.forEach(emp => { %>
              <tr>
                <td>
                  <strong><%= emp.first_name %> <%= emp.last_name %></strong>
                </td>
                <td><code><%= emp.login_id %></code></td>
                <td><%= emp.email %></td>
                <td>
                  <span style="font-size: 0.85rem; padding: 0.2rem 0.5rem; border-radius: 4px; font-weight: 600; 
                    background-color: <%= emp.role === 'admin' ? '#f5e7e1' : '#eaf2eb' %>;
                    color: <%= emp.role === 'admin' ? 'var(--primary)' : 'var(--accent)' %>">
                    <%= emp.role %>
                  </span>
                </td>
                <td style="font-size: 0.85rem; color: var(--text-light);"><%= emp.joining_year %></td>
                <td>
                  <div style="display: flex; gap: 8px;">
                    <a href="/hr/edit/<%= emp.id %>" class="btn btn-secondary" style="padding: 0.3rem 0.6rem; font-size: 0.8rem; display: inline-flex; align-items: center;">
                      <span class="material-symbols-outlined" style="font-size: 16px;">edit</span>
                    </a>
                    
                    <!-- Prevent admin self-deletion -->
                    <% if (emp.id !== user.id) { %>
                      <form action="/hr/delete/<%= emp.id %>" method="POST" onsubmit="return confirm('Are you sure you want to delete this employee? This action is irreversible.');">
                        <button type="submit" class="btn btn-secondary" style="padding: 0.3rem 0.6rem; font-size: 0.8rem; color: var(--danger); border-color: var(--danger); display: inline-flex; align-items: center;">
                          <span class="material-symbols-outlined" style="font-size: 16px;">delete</span>
                        </button>
                      </form>
                    <% } %>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <p style="text-align: center; color: var(--text-light); padding: 3rem 0;">No employees registered yet.</p>
    <% } %>
  </div>
</div>

<%- include('../layouts/footer') %>
