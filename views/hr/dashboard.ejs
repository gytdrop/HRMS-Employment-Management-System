<%- include('../layouts/header') %>

<style>
  /* ── HR Dashboard local styles ─────────────────────────── */
  .hr-layout {
    display: grid;
    grid-template-columns: 340px 1fr;
    gap: 1.5rem;
    align-items: start;
  }
  @media (max-width: 860px) { .hr-layout { grid-template-columns: 1fr; } }

  /* Role badge */
  .role-badge {
    display: inline-block;
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: capitalize;
    letter-spacing: 0.04em;
  }
  .role-badge.admin    { background: #f5e7e1; color: var(--primary); }
  .role-badge.employee { background: #eaf2eb; color: var(--accent); }

  /* Avatar initials */
  .emp-avatar {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-weight: 700;
    font-size: 0.78rem;
    flex-shrink: 0;
  }

  /* Onboarding form card */
  .onboard-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    position: sticky;
    top: calc(var(--topbar-height) + 1rem);
  }
  .onboard-card-header {
    background: linear-gradient(135deg, var(--primary) 0%, #a0431e 100%);
    color: #fff;
    padding: 1.1rem 1.25rem;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .onboard-card-header h3 {
    margin: 0;
    font-size: 1rem;
    font-weight: 600;
    color: #fff;
  }
  .onboard-card-body { padding: 1.25rem; }

  /* Directory card */
  .dir-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }
  .dir-card-header {
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--border-color);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .dir-card-header h3 { margin: 0; font-size: 1rem; }
  .emp-count-badge {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 999px;
    padding: 0.15rem 0.65rem;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--text-secondary);
  }
</style>

<!-- ── Page hero ──────────────────────────────────────────── -->
<div class="page-hero">
  <h1>Employee Management</h1>
  <p style="margin:0; font-size:0.85rem;">Onboard new staff and manage roles &amp; permissions.</p>
</div>

<!-- ── Flash messages ─────────────────────────────────────── -->
<% if (error) { %>
  <div class="alert alert-error">
    <span class="material-symbols-outlined">error</span>
    <span><%- error %></span>
  </div>
<% } %>

<% if (success) { %>
  <div class="alert alert-success">
    <span class="material-symbols-outlined">check_circle</span>
    <span><%- success %></span>
  </div>
<% } %>

<div class="hr-layout">

  <!-- ── Onboarding Form ───────────────────────────────────── -->
  <div class="onboard-card">
    <div class="onboard-card-header">
      <span class="material-symbols-outlined">person_add</span>
      <h3>Onboard New Employee</h3>
    </div>
    <div class="onboard-card-body">
      <form action="/hr/create" method="POST">

        <div class="form-group">
          <label class="form-label" for="firstName">First Name</label>
          <input type="text" id="firstName" name="firstName" class="form-input"
                 placeholder="e.g. Naveen" required autocomplete="off" />
        </div>

        <div class="form-group">
          <label class="form-label" for="lastName">Last Name</label>
          <input type="text" id="lastName" name="lastName" class="form-input"
                 placeholder="e.g. Kumar" required autocomplete="off" />
        </div>

        <div class="form-group">
          <label class="form-label" for="email">Work Email</label>
          <input type="email" id="email" name="email" class="form-input"
                 placeholder="e.g. naveen@company.com" required autocomplete="off" />
        </div>

        <div class="form-group" style="margin-bottom:1.5rem;">
          <label class="form-label" for="role">System Role</label>
          <select id="role" name="role" class="form-input" style="appearance:auto; cursor:pointer;" required>
            <option value="employee">Employee (Read-Only)</option>
            <option value="admin">Admin / HR Officer</option>
          </select>
          <div style="font-size:0.72rem; color:var(--text-light); margin-top:0.4rem; display:flex; align-items:center; gap:4px;">
            <span class="material-symbols-outlined" style="font-size:13px;">info</span>
            A login ID and random password will be auto-generated.
          </div>
        </div>

        <button type="submit" id="onboard-submit" class="btn btn-primary" style="width:100%; justify-content:center; font-weight:600; gap:6px;">
          <span class="spinner"></span>
          <span class="material-symbols-outlined" style="font-size:18px;">how_to_reg</span>
          Register &amp; Generate ID
        </button>
      </form>
    </div>
  </div>

  <!-- ── Employee Directory ────────────────────────────────── -->
  <div class="dir-card">
    <div class="dir-card-header">
      <h3>Employee Directory</h3>
      <% if (employees && employees.length > 0) { %>
        <span class="emp-count-badge"><%= employees.length %> member<%= employees.length !== 1 ? 's' : '' %></span>
      <% } %>
    </div>

    <% if (employees && employees.length > 0) { %>
      <div class="table-container" style="border:none; border-radius:0; margin-bottom:0;">
        <table>
          <thead>
            <tr>
              <th>Employee</th>
              <th>Login ID</th>
              <th>Email</th>
              <th>Role</th>
              <th>Joined</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% employees.forEach(function(emp) { %>
              <tr>
                <td>
                  <div style="display:flex; align-items:center; gap:9px;">
                    <div class="emp-avatar">
                      <%= emp.first_name[0].toUpperCase() %><%= emp.last_name[0].toUpperCase() %>
                    </div>
                    <div>
                      <div style="font-weight:600; font-size:0.9rem;"><%= emp.first_name %> <%= emp.last_name %></div>
                    </div>
                  </div>
                </td>
                <td><code style="font-size:0.78rem; background:var(--bg-secondary); padding:0.15rem 0.4rem; border-radius:4px;"><%= emp.login_id %></code></td>
                <td style="font-size:0.85rem; color:var(--text-secondary);"><%= emp.email %></td>
                <td>
                  <span class="role-badge <%= emp.role %>"><%= emp.role %></span>
                </td>
                <td style="font-size:0.82rem; color:var(--text-light)"><%= emp.joining_year %></td>
                <td>
                  <div style="display:flex; gap:6px; align-items:center;">
                    <a href="/hr/edit/<%= emp.id %>" class="btn btn-secondary"
                       style="padding:0.3rem 0.6rem; font-size:0.8rem; display:inline-flex; align-items:center; gap:3px;"
                       title="Edit employee">
                      <span class="material-symbols-outlined" style="font-size:15px;">edit</span>
                    </a>
                    <% if (emp.id !== user.id) { %>
                      <form action="/hr/delete/<%= emp.id %>" method="POST"
                            onsubmit="return confirm('Delete <%= emp.first_name %> <%= emp.last_name %>? This cannot be undone.');">
                        <button type="submit" class="btn btn-secondary"
                                style="padding:0.3rem 0.6rem; font-size:0.8rem; color:var(--danger); border-color:var(--danger); display:inline-flex; align-items:center; gap:3px;"
                                title="Delete employee">
                          <span class="material-symbols-outlined" style="font-size:15px;">delete</span>
                        </button>
                      </form>
                    <% } %>
                  </div>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="empty-state">
        <div class="empty-icon">
          <span class="material-symbols-outlined">group_add</span>
        </div>
        <div class="empty-title">No employees yet</div>
        <p class="empty-desc">Use the form on the left to onboard your first team member.</p>
      </div>
    <% } %>
  </div>

</div>

<%- include('../layouts/footer') %>
