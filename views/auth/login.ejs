<%- include('../layouts/header') %>

<style>
  body { overflow: hidden; }

  .login-bg {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: radial-gradient(ellipse at 30% 50%, rgba(200,90,50,0.06) 0%, transparent 65%),
                radial-gradient(ellipse at 70% 20%, rgba(230,161,92,0.05) 0%, transparent 55%),
                var(--bg-primary);
    padding: 1.5rem;
    position: relative;
  }

  /* ── Clean & Premium Card Layout ── */
  .login-card {
    width: 100%;
    max-width: 400px;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: 2.25rem 2rem;
    box-shadow: var(--shadow-md);
    animation: fadeSlideUp 0.35s ease forwards;
  }

  .login-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 2rem;
  }

  .login-logo .logo-icon {
    font-size: 26px;
    color: var(--primary);
  }

  .login-logo h1 {
    font-size: 1.35rem;
    font-weight: 700;
    margin: 0;
    color: var(--text-primary);
    letter-spacing: -0.5px;
  }

  /* ── Interactive Demo Button ── */
  .demo-accounts-btn {
    width: 100%;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
    padding: 0.65rem 0.85rem;
    border-radius: var(--radius-sm);
    font-size: 0.82rem;
    font-weight: 500;
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .demo-accounts-btn:hover {
    background: var(--border-color);
    color: var(--text-primary);
  }

  .demo-accounts-btn .badge-pill {
    background: var(--primary);
    color: #fff;
    font-size: 0.72rem;
    padding: 0.1rem 0.5rem;
    border-radius: 99px;
    font-weight: 600;
  }

  /* ── Slide-up Credential Sheet ── */
  #inbox-panel {
    position: fixed;
    bottom: 0;
    left: 50%;
    transform: translate(-50%, 110%);
    width: 100%;
    max-width: 440px;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md) var(--radius-md) 0 0;
    box-shadow: var(--shadow-lg);
    z-index: 300;
    display: flex;
    flex-direction: column;
    max-height: 80vh;
    transition: transform 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  #inbox-panel.is-open {
    transform: translate(-50%, 0);
  }

  .inbox-header {
    padding: 1.1rem 1.25rem;
    border-bottom: 1px solid var(--border-color);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .inbox-header h3 {
    margin: 0;
    font-size: 0.95rem;
    color: var(--text-primary);
    font-weight: 600;
  }

  .inbox-close-btn {
    background: none;
    border: none;
    cursor: pointer;
    display: inline-flex;
    color: var(--text-secondary);
  }

  .inbox-close-btn:hover { color: var(--text-primary); }

  #inbox-list {
    overflow-y: auto;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .inbox-item {
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm);
    padding: 0.85rem 1rem;
    transition: border-color 0.15s;
  }

  .inbox-item.unread {
    border-left: 3px solid var(--primary);
  }

  .emp-header {
    font-weight: 600;
    font-size: 0.88rem;
    margin-bottom: 0.5rem;
    color: var(--text-primary);
  }

  .cred-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.8rem;
    margin-bottom: 0.35rem;
  }

  .cred-label {
    color: var(--text-light);
  }

  .copyable-val {
    font-family: monospace;
    font-weight: 600;
    background: var(--bg-secondary);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    cursor: pointer;
    border: none;
    color: var(--text-primary);
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }

  .copyable-val:hover {
    background: var(--border-color);
  }

  .copyable-val .material-symbols-outlined {
    font-size: 13px;
    color: var(--text-light);
  }

  .inbox-notice {
    font-size: 0.72rem;
    color: var(--text-secondary);
    padding: 0.75rem 1.25rem;
    background: var(--bg-secondary);
    border-bottom: 1px solid var(--border-color);
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .inbox-notice .material-symbols-outlined { font-size: 14px; color: var(--primary); }

  /* ── Overlay Backing ── */
  #inbox-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(2px);
    z-index: 290;
    display: none;
  }

  #inbox-overlay.is-open { display: block; }
</style>

<div class="login-bg">
  <div class="login-card">
    <div class="login-logo">
      <span class="material-symbols-outlined logo-icon">domain</span>
      <h1>Adamas HRMS</h1>
    </div>

    <!-- Interactive demo trigger replaced floating M button to look natural -->
    <button class="demo-accounts-btn" onclick="openInbox()">
      <span>Demo Onboarded Passwords</span>
      <span class="badge-pill" id="demo-badge" style="display:none;">0</span>
    </button>

    <% if (error) { %>
      <div class="alert alert-error" style="margin-bottom: 1.25rem;">
        <span class="material-symbols-outlined">error</span>
        <span><%= error %></span>
      </div>
    <% } %>

    <form action="/auth/login" method="POST">
      <div class="form-group">
        <label class="form-label" for="loginOrEmail">Login ID or Email</label>
        <input type="text" id="loginOrEmail" name="loginOrEmail" class="form-input"
               placeholder="e.g. ADAMASASPA2026001" required autofocus autocomplete="username" />
      </div>

      <div class="form-group" style="margin-bottom: 1.75rem;">
        <label class="form-label" for="password">Password</label>
        <input type="password" id="password" name="password" class="form-input"
               placeholder="••••••••" required autocomplete="current-password" />
      </div>

      <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center; padding: 0.8rem; font-weight: 600;">
        <span class="spinner"></span>
        Sign In
      </button>
    </form>
  </div>
</div>

<!-- Backdrop and Sheet panel -->
<div id="inbox-overlay" onclick="closeInbox()"></div>

<div id="inbox-panel">
  <div class="inbox-header">
    <h3>Demo Accounts &amp; Passwords</h3>
    <button class="inbox-close-btn" onclick="closeInbox()">
      <span class="material-symbols-outlined">close</span>
    </button>
  </div>
  <div class="inbox-notice">
    <span class="material-symbols-outlined">info</span>
    <span>Click any field to copy. Change password upon first login.</span>
  </div>
  <div id="inbox-list">
    <div style="text-align:center; color:var(--text-light); font-size:0.85rem; padding:2rem 0;">
      Loading accounts…
    </div>
  </div>
</div>

<script>
  function openInbox() {
    document.getElementById('inbox-overlay').classList.add('is-open');
    document.getElementById('inbox-panel').classList.add('is-open');
    loadInbox();
  }

  function closeInbox() {
    document.getElementById('inbox-overlay').classList.remove('is-open');
    document.getElementById('inbox-panel').classList.remove('is-open');
    fetch('/auth/inbox/read', { method: 'POST' }).catch(function() {});
    document.getElementById('demo-badge').style.display = 'none';
  }

  function loadInbox() {
    fetch('/auth/inbox')
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var list = document.getElementById('inbox-list');
        if (!data.items || data.items.length === 0) {
          list.innerHTML = '<div style="text-align:center; color:var(--text-light); font-size:0.85rem; padding:2rem 0;">No new employee accounts found.</div>';
          return;
        }

        list.innerHTML = data.items.map(function(item) {
          var unread = item.is_read ? '' : ' unread';
          return '<div class="inbox-item' + unread + '">' +
            '<div class="emp-header">' + escapeHtml(item.employee_name) + '</div>' +
            '<div class="cred-row">' +
              '<span class="cred-label">Login ID</span>' +
              '<button class="copyable-val" onclick="copyText(\'' + escapeHtml(item.login_id) + '\', this)">' +
                escapeHtml(item.login_id) +
                '<span class="material-symbols-outlined">content_copy</span>' +
              '</button>' +
            '</div>' +
            '<div class="cred-row">' +
              '<span class="cred-label">Temp Password</span>' +
              '<button class="copyable-val" onclick="copyText(\'' + escapeHtml(item.temp_password) + '\', this)">' +
                escapeHtml(item.temp_password) +
                '<span class="material-symbols-outlined">content_copy</span>' +
              '</button>' +
            '</div>' +
          '</div>';
        }).join('');
      })
      .catch(function() {
        document.getElementById('inbox-list').innerHTML = '<div style="text-align:center; color:var(--text-light); font-size:0.85rem; padding:2rem 0;">Failed to load accounts.</div>';
      });
  }

  function copyText(text, btn) {
    navigator.clipboard.writeText(text).then(function() {
      var icon = btn.querySelector('.material-symbols-outlined');
      if (icon) {
        icon.textContent = 'check';
        setTimeout(function() { icon.textContent = 'content_copy'; }, 1200);
      }
    });
  }

  function escapeHtml(str) {
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  window.addEventListener('DOMContentLoaded', function() {
    fetch('/auth/inbox')
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var unread = (data.items || []).filter(function(i) { return !i.is_read; }).length;
        var badge = document.getElementById('demo-badge');
        if (unread > 0) {
          badge.textContent = unread;
          badge.style.display = 'inline-block';
        }
      })
      .catch(function() {});
  });
</script>

<%- include('../layouts/footer') %>
