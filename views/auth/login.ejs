<%- include('../layouts/header') %>

<div class="card" style="max-width: 420px; margin: 6rem auto; padding: 2.5rem; border-radius: var(--radius-lg); box-shadow: var(--shadow-lg);">
  <div style="text-align: center; margin-bottom: 2rem;">
    <h1 style="color: var(--primary); font-weight: 700; font-size: 2.25rem; letter-spacing: -1px; margin-bottom: 0.25rem;">HRMS</h1>
    <p style="font-size: 0.9rem; color: var(--text-secondary);">Sign in to access your dashboard</p>
  </div>

  <% if (error) { %>
    <script>window.addEventListener('DOMContentLoaded', function () { showToast(<%- JSON.stringify(error) %>, 'error'); });</script>
  <% } %>

  <form action="/auth/login" method="POST">
    <div class="form-group">
      <label class="form-label" for="loginOrEmail">Login ID or Email Address</label>
      <input type="text" id="loginOrEmail" name="loginOrEmail" class="form-input" placeholder="e.g. ADAMASASPA2026001" required autofocus />
    </div>

    <div class="form-group" style="margin-bottom: 2rem;">
      <label class="form-label" for="password">Password</label>
      <input type="password" id="password" name="password" class="form-input" placeholder="••••••••" required />
    </div>

    <button type="submit" class="btn btn-primary" style="width: 100%; padding: 0.9rem; border-radius: var(--radius-sm); font-weight: 600;">
      Sign In
    </button>
  </form>
</div>

<%- include('../layouts/footer') %>
