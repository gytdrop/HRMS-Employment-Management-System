<%- include('../layouts/header') %>

<style>
  /* ── Login page full-height center ─────────────────────── */
  body { overflow: hidden; }

  .login-bg {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: radial-gradient(ellipse at 30% 50%, rgba(200,90,50,0.08) 0%, transparent 60%),
                radial-gradient(ellipse at 70% 20%, rgba(230,161,92,0.07) 0%, transparent 50%),
                var(--bg-primary);
    padding: 1rem;
    position: relative;
  }

  /* ── Login card ─────────────────────────────────────────── */
  .login-card {
    width: 100%;
    max-width: 400px;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 2.5rem 2.25rem 2rem;
    box-shadow: var(--shadow-lg);
    animation: fadeSlideUp 0.4s ease forwards;
  }

  .login-logo {
    text-align: center;
    margin-bottom: 1.75rem;
  }

  .login-logo .logo-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 54px;
    height: 54px;
    background: linear-gradient(135deg, var(--primary), #a0431e);
    border-radius: var(--radius-md);
    margin-bottom: 0.85rem;
    box-shadow: 0 6px 20px rgba(200,90,50,0.3);
  }

  .login-logo .logo-mark span {
    font-size: 1.6rem;
    font-weight: 800;
    color: #fff;
    letter-spacing: -1px;
    font-family: var(--font-primary);
  }

  .login-logo h1 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 0.2rem;
    color: var(--text-primary);
  }

  .login-logo p {
    font-size: 0.82rem;
    color: var(--text-light);
    margin: 0;
  }

  /* ── Inbox FAB button ───────────────────────────────────── */
  #inbox-fab {
    position: fixed;
    bottom: 1.75rem;
    right: 1.75rem;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--primary), #a0431e);
    color: #fff;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 6px 20px rgba(200,90,50,0.35);
    transition: transform 0.2s, box-shadow 0.2s;
    z-index: 200;
    font-family: var(--font-primary);
    font-size: 1.1rem;
    font-weight: 800;
    letter-spacing: -0.5px;
  }

  #inbox-fab:hover {
    transform: translateY(-3px) scale(1.06);
    box-shadow: 0 10px 28px rgba(200,90,50,0.45);
  }

  /* Unread badge */
  .fab-badge {
    position: absolute;
    top: -3px;
    right: -3px;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: #e06060;
    border: 2px solid var(--bg-primary);
    font-size: 0.62rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    display: none;
  }

  /* ── Inbox slide-in panel ───────────────────────────────── */
  #inbox-panel {
    position: fixed;
    bottom: 0;
    right: 0;
    width: 370px;
    max-width: 100vw;
    max-height: 85vh;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
    box-shadow: var(--shadow-lg);
    z-index: 300;
    display: flex;
    flex-direction: column;
    transform: translateY(110%);
    transition: transform 0.35s cubic-bezier(0.34, 1.3, 0.64, 1);
  }

  #inbox-panel.is-open {
    transform: translateY(0);
  }

  .inbox-header {
    padding: 1rem 1.25rem 0.75rem;
    border-bottom: 1px solid var(--border-color);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-shrink: 0;
  }

  .inbox-header-left {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .inbox-header-icon {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    background: linear-gradient(135deg, var(--primary), #a0431e);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-weight: 800;
    font-size: 0.9rem;
    font-family: var(--font-primary);
  }

  .inbox-header h3 {
    margin: 0;
    font-size: 0.95rem;
    color: var(--text-primary);
  }

  .inbox-header .inbox-subtitle {
    font-size: 0.7rem;
    color: var(--text-light);
    margin: 0;
  }

  .inbox-close-btn {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.15s;
  }

  .inbox-close-btn:hover { background: var(--bg-primary); }
  .inbox-close-btn .material-symbols-outlined { font-size: 16px; color: var(--text-secondary); }

  /* Notice banner */
  .inbox-notice {
    margin: 0.75rem 1.25rem 0;
    padding: 0.6rem 0.85rem;
    background: #fff8f0;
    border: 1px solid #f0c080;
    border-radius: var(--radius-sm);
    font-size: 0.72rem;
    color: #7a5530;
    display: flex;
    align-items: flex-start;
    gap: 6px;
    flex-shrink: 0;
  }
  :root[data-theme="dark"] .inbox-notice {
    background: #2e2318;
    border-color: #5a3e1a;
    color: #c9a05a;
  }
  .inbox-notice .material-symbols-outlined { font-size: 14px; flex-shrink: 0; margin-top: 1px; }

  /* Items list */
  #inbox-list {
    overflow-y: auto;
    flex: 1;
    padding: 0.75rem 1.25rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .inbox-item {
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: 0.9rem 1rem;
    position: relative;
    transition: box-shadow 0.15s;
  }

  .inbox-item.unread {
    border-left: 3px solid var(--primary);
    background: linear-gradient(135deg, rgba(200,90,50,0.04) 0%, var(--bg-primary) 100%);
  }

  .inbox-item:hover { box-shadow: var(--shadow-md); }

  .inbox-item .emp-name {
    font-weight: 600;
    font-size: 0.88rem;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .inbox-item .emp-name .material-symbols-outlined {
    font-size: 16px;
    color: var(--primary);
  }

  .cred-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.3rem;
  }

  .cred-row .cred-label {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-light);
  }

  .cred-row .cred-val {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--text-primary);
    font-family: monospace;
    background: var(--bg-secondary);
    padding: 0.1rem 0.45rem;
    border-radius: 4px;
    cursor: pointer;
    transition: background 0.15s;
    display: flex;
    align-items: center;
    gap: 4px;
    border: none;
    user-select: all;
  }

  .cred-row .cred-val:hover { background: var(--border-color); }
  .cred-row .cred-val .material-symbols-outlined { font-size: 12px; color: var(--text-light); }

  .inbox-item .item-time {
    font-size: 0.68rem;
    color: var(--text-light);
    margin-top: 0.45rem;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .inbox-item .item-time .material-symbols-outlined { font-size: 12px; }

  .inbox-change-hint {
    font-size: 0.68rem;
    color: var(--accent);
    margin-top: 0.4rem;
    display: flex;
    align-items: center;
    gap: 4px;
    font-weight: 500;
  }

  .inbox-change-hint .material-symbols-outlined { font-size: 12px; }

  /* Empty / loading states */
  .inbox-empty {
    text-align: center;
    padding: 2rem 1rem;
    color: var(--text-light);
    font-size: 0.85rem;
  }

  .inbox-empty .material-symbols-outlined { font-size: 2.5rem; display: block; margin-bottom: 0.5rem; }
</style>

<div class="login-bg">

  <!-- ── Login Card ──────────────────────────────────────── -->
  <div class="login-card">
    <div class="login-logo">
      <div class="logo-mark"><span>HR</span></div>
      <h1>Welcome back</h1>
      <p>Sign in to access your HRMS dashboard</p>
    </div>

    <% if (error) { %>
      <div class="alert alert-error" style="margin-bottom:1.25rem;">
        <span class="material-symbols-outlined">error</span>
        <span><%= error %></span>
      </div>
    <% } %>

    <form action="/auth/login" method="POST">
      <div class="form-group">
        <label class="form-label" for="loginOrEmail">Login ID or Email</label>
        <input type="text" id="loginOrEmail" name="loginOrEmail" class="form-input"
               placeholder="e.g. ADAMASASPA2026001" required autofocus autocomplete="username" />
      </div>

      <div class="form-group" style="margin-bottom:1.75rem;">
        <label class="form-label" for="password">Password</label>
        <input type="password" id="password" name="password" class="form-input"
               placeholder="••••••••" required autocomplete="current-password" />
      </div>

      <button type="submit" class="btn btn-primary" style="width:100%; justify-content:center; padding:0.85rem; font-weight:600; font-size:1rem;">
        <span class="spinner"></span>
        Sign In
      </button>
    </form>
  </div>

  <!-- ── "M" Inbox FAB ──────────────────────────────────── -->
  <button id="inbox-fab" onclick="toggleInbox()" title="View generated credentials">
    M
    <span class="fab-badge" id="fab-badge"></span>
  </button>

  <!-- ── Inbox Slide Panel ──────────────────────────────── -->
  <div id="inbox-panel">
    <div class="inbox-header">
      <div class="inbox-header-left">
        <div class="inbox-header-icon">M</div>
        <div>
          <h3>Credential Inbox</h3>
          <p class="inbox-subtitle">Auto-generated employee passwords</p>
        </div>
      </div>
      <button class="inbox-close-btn" onclick="closeInbox()">
        <span class="material-symbols-outlined">close</span>
      </button>
    </div>

    <div class="inbox-notice">
      <span class="material-symbols-outlined">info</span>
      <span>These are <strong>temporary passwords</strong>. Each employee must change their password on first login.</span>
    </div>

    <div id="inbox-list">
      <div class="inbox-empty">
        <span class="material-symbols-outlined">hourglass_empty</span>
        Loading…
      </div>
    </div>
  </div>

</div>

<script>
  var inboxOpen = false;

  function toggleInbox() {
    if (inboxOpen) closeInbox();
    else openInbox();
  }

  function openInbox() {
    inboxOpen = true;
    document.getElementById('inbox-panel').classList.add('is-open');
    loadInbox();
  }

  function closeInbox() {
    inboxOpen = false;
    document.getElementById('inbox-panel').classList.remove('is-open');
    // Mark all as read on close
    fetch('/auth/inbox/read', { method: 'POST' }).catch(function() {});
    document.getElementById('fab-badge').style.display = 'none';
  }

  function loadInbox() {
    fetch('/auth/inbox')
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var list = document.getElementById('inbox-list');
        if (!data.items || data.items.length === 0) {
          list.innerHTML = '<div class="inbox-empty"><span class="material-symbols-outlined">inbox</span>No credentials yet. Onboard an employee first.</div>';
          return;
        }

        list.innerHTML = data.items.map(function(item) {
          var unreadClass = item.is_read ? '' : ' unread';
          return '<div class="inbox-item' + unreadClass + '">' +
            '<div class="emp-name">' +
              '<span class="material-symbols-outlined">person</span>' +
              escapeHtml(item.employee_name) +
            '</div>' +
            '<div class="cred-row">' +
              '<span class="cred-label">Login ID</span>' +
              '<button class="cred-val" onclick="copyText(\'' + escapeHtml(item.login_id) + '\', this)" title="Click to copy">' +
                escapeHtml(item.login_id) +
                '<span class="material-symbols-outlined">content_copy</span>' +
              '</button>' +
            '</div>' +
            '<div class="cred-row">' +
              '<span class="cred-label">Temp Password</span>' +
              '<button class="cred-val" onclick="copyText(\'' + escapeHtml(item.temp_password) + '\', this)" title="Click to copy">' +
                escapeHtml(item.temp_password) +
                '<span class="material-symbols-outlined">content_copy</span>' +
              '</button>' +
            '</div>' +
            '<div class="cred-row">' +
              '<span class="cred-label">Email</span>' +
              '<span style="font-size:0.78rem; color:var(--text-secondary);">' + escapeHtml(item.email) + '</span>' +
            '</div>' +
            '<div class="inbox-change-hint">' +
              '<span class="material-symbols-outlined">lock_reset</span>' +
              'Employee must change password on first login' +
            '</div>' +
            '<div class="item-time">' +
              '<span class="material-symbols-outlined">schedule</span>' +
              escapeHtml(item.created_label) +
            '</div>' +
          '</div>';
        }).join('');
      })
      .catch(function() {
        document.getElementById('inbox-list').innerHTML = '<div class="inbox-empty">Failed to load. Is the server running?</div>';
      });
  }

  function copyText(text, btn) {
    navigator.clipboard.writeText(text).then(function() {
      var icon = btn.querySelector('.material-symbols-outlined');
      if (icon) {
        icon.textContent = 'check';
        setTimeout(function() { icon.textContent = 'content_copy'; }, 1500);
      }
    }).catch(function() {
      // fallback: select text
      btn.focus();
      document.execCommand('selectAll');
    });
  }

  function escapeHtml(str) {
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  // Auto-check for unread on page load
  window.addEventListener('DOMContentLoaded', function() {
    fetch('/auth/inbox')
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var unread = (data.items || []).filter(function(i) { return !i.is_read; }).length;
        var badge = document.getElementById('fab-badge');
        if (unread > 0) {
          badge.textContent = unread > 9 ? '9+' : unread;
          badge.style.display = 'flex';
        }
      })
      .catch(function() {});
  });
</script>

<%- include('../layouts/footer') %>
