<%- include('../layouts/header') %>

<style>
  /* ── Payroll Premium Styles ────────────────────────────── */
  .payroll-hero {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2.5rem;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .payroll-hero-text h1 { margin-bottom: 0.25rem; }
  .payroll-hero-text p  { margin: 0; }

  /* Stat strip */
  .stat-strip {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .stat-card {
    background: linear-gradient(135deg, var(--bg-card) 0%, var(--bg-secondary) 100%);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .stat-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }
  .stat-card .stat-icon {
    font-size: 1.6rem;
    color: var(--primary);
    margin-bottom: 0.2rem;
  }
  .stat-card .stat-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1;
  }
  .stat-card .stat-label {
    font-size: 0.78rem;
    color: var(--text-light);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* Admin salary table */
  .payroll-table-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
  }
  .payroll-table-card-header {
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid var(--border-color);
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .payroll-table-card-header h3 { margin: 0; font-size: 1.05rem; }
  .payroll-table-card-header .material-symbols-outlined { color: var(--primary); }

  .payroll-admin-table th { background-color: var(--bg-secondary); }
  .payroll-admin-table tr:hover td { background-color: #faf8f5; }

  .wage-input-wrap {
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .wage-input-wrap .currency-sym {
    font-weight: 600;
    color: var(--text-secondary);
    font-size: 0.95rem;
  }
  .compact-input {
    padding: 0.3rem 0.5rem !important;
    width: 100px !important;
    font-size: 0.9rem !important;
    border-radius: 6px !important;
  }
  .btn-save {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    color: var(--text-primary);
    padding: 0.35rem 0.85rem;
    border-radius: 6px;
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.18s, transform 0.1s;
    white-space: nowrap;
  }
  .btn-save:hover { background: #e6dfd3; transform: translateY(-1px); }

  .btn-gen {
    background: var(--accent);
    color: white;
    border: none;
    padding: 0.35rem 0.8rem;
    border-radius: 6px;
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.18s, transform 0.1s;
    white-space: nowrap;
  }
  .btn-gen:hover { opacity: 0.88; transform: translateY(-1px); }

  .period-input {
    padding: 0.3rem 0.45rem !important;
    font-size: 0.82rem !important;
    width: 130px !important;
    border-radius: 6px !important;
  }

  /* Employee view — salary breakdown */
  .salary-breakdown-grid {
    display: grid;
    grid-template-columns: 360px 1fr;
    gap: 1.75rem;
    align-items: start;
  }
  @media (max-width: 860px) { .salary-breakdown-grid { grid-template-columns: 1fr; } }

  .breakdown-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }
  .breakdown-card-header {
    background: linear-gradient(135deg, var(--primary) 0%, #a0431e 100%);
    color: white;
    padding: 1.4rem 1.5rem;
  }
  .breakdown-card-header .bc-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.8;
    margin-bottom: 0.3rem;
  }
  .breakdown-card-header .bc-amount {
    font-size: 2.4rem;
    font-weight: 700;
    line-height: 1;
    letter-spacing: -1px;
  }
  .breakdown-card-header .bc-period { font-size: 0.82rem; opacity: 0.75; margin-top: 0.25rem; }

  .breakdown-rows { padding: 1.25rem 1.5rem; }
  .breakdown-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.8rem 0;
    border-bottom: 1px solid var(--border-color);
  }
  .breakdown-row:last-child { border-bottom: none; }
  .breakdown-row .br-label { color: var(--text-secondary); font-size: 0.9rem; }
  .breakdown-row .br-pct  { font-size: 0.75rem; color: var(--text-light); margin-top: 2px; }
  .breakdown-row .br-amt  { font-weight: 600; font-size: 1rem; }

  .breakdown-total {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: linear-gradient(135deg, #eaf2eb, #d9eed8);
    border-radius: var(--radius-sm);
    padding: 1rem 1.25rem;
    margin: 1.25rem 1.5rem 1.5rem;
  }
  .breakdown-total .bt-label { font-weight: 600; color: var(--text-primary); }
  .breakdown-total .bt-amount { font-size: 1.4rem; font-weight: 700; color: var(--accent); }

  /* Payslip history table */
  .payslip-history-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }
  .payslip-history-header {
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid var(--border-color);
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .payslip-history-header h3 { margin: 0; font-size: 1.05rem; }
  .payslip-history-header .material-symbols-outlined { color: var(--accent); }

  .payslip-row-net { font-weight: 700; color: var(--accent); font-size: 1rem; }
  .period-badge {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 20px;
    padding: 0.2rem 0.7rem;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: 0.03em;
  }
  .btn-view-slip {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    background: var(--primary);
    color: white;
    padding: 0.35rem 0.8rem;
    border-radius: 6px;
    font-size: 0.82rem;
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.18s, transform 0.1s;
  }
  .btn-view-slip:hover { opacity: 0.88; transform: translateY(-1px); }

  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 4rem 2rem;
    gap: 0.75rem;
    color: var(--text-light);
  }
  .empty-state .material-symbols-outlined { font-size: 3rem; }
  .empty-state p { margin: 0; font-size: 0.95rem; }

  /* Alert messages */
  .alert {
    display: flex; align-items: center; gap: 10px;
    padding: 0.85rem 1rem; border-radius: var(--radius-sm);
    font-size: 0.9rem; margin-bottom: 1.5rem;
  }
  .alert-error  { background: #fbebeb; color: var(--danger); border: 1px solid #f6d1d1; }
  .alert-success{ background: #eaf2eb; color: var(--accent); border: 1px solid #d2e4d5; }
  .alert .material-symbols-outlined { font-size: 20px; flex-shrink: 0; }
</style>

<!-- ── Page Hero ─────────────────────────────────────────── -->
<div class="payroll-hero">
  <div class="payroll-hero-text">
    <h1>Payroll Management</h1>
    <% if (user.role === 'admin') { %>
      <p>Configure salary structures and generate monthly payslips for all employees.</p>
    <% } else { %>
      <p>View your salary breakdown and download monthly payslips.</p>
    <% } %>
  </div>
</div>

<!-- ── Alerts (rendered as toasts via global app.js) ────── -->
<% if (error) { %>
  <script>window.addEventListener('DOMContentLoaded', function () { showToast(<%- JSON.stringify(error) %>, 'error'); });</script>
<% } %>
<% if (success) { %>
  <script>window.addEventListener('DOMContentLoaded', function () { showToast(<%- JSON.stringify(success) %>, 'success'); });</script>
<% } %>

<!-- ═══════════════════════ ADMIN VIEW ═══════════════════════ -->
<% if (user.role === 'admin') { %>

  <% if (structures && structures.length > 0) {
    const totalWage   = structures.reduce((s,r) => s + parseFloat(r.base_wage || 0), 0);
    const totalNet    = structures.reduce((s,r) => s + parseFloat(r.basic_salary||0) + parseFloat(r.hra||0) + parseFloat(r.other_allowances||0), 0);
    const configured  = structures.filter(r => parseFloat(r.base_wage) > 0).length;
  %>
  <!-- Stat strip -->
  <div class="stat-strip">
    <div class="stat-card">
      <span class="material-symbols-outlined stat-icon">groups</span>
      <span class="stat-value"><%= structures.length %></span>
      <span class="stat-label">Total Employees</span>
    </div>
    <div class="stat-card">
      <span class="material-symbols-outlined stat-icon" style="color: var(--accent);">task_alt</span>
      <span class="stat-value"><%= configured %></span>
      <span class="stat-label">Salary Configured</span>
    </div>
    <div class="stat-card">
      <span class="material-symbols-outlined stat-icon" style="color: var(--secondary);">account_balance</span>
      <span class="stat-value">₹<%= totalWage.toLocaleString('en-IN', {maximumFractionDigits:0}) %></span>
      <span class="stat-label">Total Wage Bill</span>
    </div>
    <div class="stat-card">
      <span class="material-symbols-outlined stat-icon" style="color: #557a62;">payments</span>
      <span class="stat-value">₹<%= totalNet.toLocaleString('en-IN', {maximumFractionDigits:0}) %></span>
      <span class="stat-label">Total Net Payout</span>
    </div>
  </div>
  <% } %>

  <!-- Salary table -->
  <div class="payroll-table-card">
    <div class="payroll-table-card-header">
      <span class="material-symbols-outlined">manage_accounts</span>
      <h3>Employee Salary Structures</h3>
    </div>

    <% if (structures && structures.length > 0) { %>
    <div style="overflow-x: auto;">
      <table class="payroll-admin-table" style="width:100%; border-collapse:collapse; text-align:left;">
        <thead>
          <tr>
            <th style="padding:0.9rem 1.25rem; border-bottom:1px solid var(--border-color); font-size:0.78rem; text-transform:uppercase; letter-spacing:0.05em; color:var(--text-secondary);">Employee</th>
            <th style="padding:0.9rem 1.25rem; border-bottom:1px solid var(--border-color); font-size:0.78rem; text-transform:uppercase; letter-spacing:0.05em; color:var(--text-secondary);">Base Wage</th>
            <th style="padding:0.9rem 1.25rem; border-bottom:1px solid var(--border-color); font-size:0.78rem; text-transform:uppercase; letter-spacing:0.05em; color:var(--text-secondary);">Basic (50%)</th>
            <th style="padding:0.9rem 1.25rem; border-bottom:1px solid var(--border-color); font-size:0.78rem; text-transform:uppercase; letter-spacing:0.05em; color:var(--text-secondary);">HRA (25%)</th>
            <th style="padding:0.9rem 1.25rem; border-bottom:1px solid var(--border-color); font-size:0.78rem; text-transform:uppercase; letter-spacing:0.05em; color:var(--text-secondary);">Other Allowances</th>
            <th style="padding:0.9rem 1.25rem; border-bottom:1px solid var(--border-color); font-size:0.78rem; text-transform:uppercase; letter-spacing:0.05em; color:var(--text-secondary);">Net Payout</th>
            <th style="padding:0.9rem 1.25rem; border-bottom:1px solid var(--border-color); font-size:0.78rem; text-transform:uppercase; letter-spacing:0.05em; color:var(--text-secondary);">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% structures.forEach(struct => {
            const net = parseFloat(struct.basic_salary||0) + parseFloat(struct.hra||0) + parseFloat(struct.other_allowances||0);
          %>
          <tr>
            <td style="padding:0.9rem 1.25rem; border-bottom:1px solid var(--border-color);">
              <div style="display:flex; align-items:center; gap:10px;">
                <div style="width:36px; height:36px; border-radius:50%; background:linear-gradient(135deg,var(--primary),var(--secondary)); display:flex; align-items:center; justify-content:center; color:white; font-weight:700; font-size:0.85rem; flex-shrink:0;">
                  <%= struct.first_name[0] %><%= struct.last_name[0] %>
                </div>
                <div>
                  <div style="font-weight:600;"><%= struct.first_name %> <%= struct.last_name %></div>
                  <div style="font-size:0.75rem; color:var(--text-light);"><code><%= struct.login_id %></code></div>
                </div>
              </div>
            </td>

            <form action="/payroll/update-structure" method="POST" style="display:contents;">
              <input type="hidden" name="employeeId" value="<%= struct.employee_id %>" />
              <td style="padding:0.9rem 1.25rem; border-bottom:1px solid var(--border-color);">
                <div class="wage-input-wrap">
                  <span class="currency-sym">₹</span>
                  <input type="number" name="baseWageInput" class="form-input compact-input" value="<%= struct.base_wage %>" step="0.01" min="0" required />
                </div>
              </td>
              <td style="padding:0.9rem 1.25rem; border-bottom:1px solid var(--border-color); font-weight:500;">₹<%= parseFloat(struct.basic_salary).toLocaleString('en-IN',{minimumFractionDigits:2}) %></td>
              <td style="padding:0.9rem 1.25rem; border-bottom:1px solid var(--border-color); font-weight:500;">₹<%= parseFloat(struct.hra).toLocaleString('en-IN',{minimumFractionDigits:2}) %></td>
              <td style="padding:0.9rem 1.25rem; border-bottom:1px solid var(--border-color);">
                <div class="wage-input-wrap">
                  <span class="currency-sym">₹</span>
                  <input type="number" name="otherAllowancesInput" class="form-input compact-input" value="<%= struct.other_allowances %>" step="0.01" min="0" required />
                </div>
              </td>
              <td style="padding:0.9rem 1.25rem; border-bottom:1px solid var(--border-color);">
                <span style="color:var(--accent); font-weight:700;">₹<%= net.toLocaleString('en-IN',{minimumFractionDigits:2}) %></span>
              </td>
              <td style="padding:0.9rem 1.25rem; border-bottom:1px solid var(--border-color);">
                <div style="display:flex; gap:8px; align-items:center; flex-wrap:wrap;">
                  <button type="submit" class="btn-save">
                    <span class="material-symbols-outlined" style="font-size:14px; vertical-align:middle;">save</span> Save
                  </button>
            </form>
                  <form action="/payroll/generate-payslip" method="POST" style="display:flex; gap:6px; align-items:center;">
                    <input type="hidden" name="employeeId" value="<%= struct.employee_id %>" />
                    <input type="month" name="payPeriod" class="form-input period-input" value="<%= new Date().toISOString().substring(0,7) %>" required />
                    <button type="submit" class="btn-gen">
                      <span class="material-symbols-outlined" style="font-size:14px; vertical-align:middle;">receipt_long</span> Generate
                    </button>
                  </form>
                </div>
              </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } else { %>
    <div class="empty-state">
      <span class="material-symbols-outlined">manage_accounts</span>
      <p>No employees found to configure.</p>
    </div>
    <% } %>
  </div>

<!-- ═══════════════════════ EMPLOYEE VIEW ═══════════════════════ -->
<% } else { %>

  <div class="salary-breakdown-grid">

    <!-- Left: Salary breakdown card -->
    <div class="breakdown-card">
      <div class="breakdown-card-header">
        <div class="bc-label">Your Monthly Net Salary</div>
        <div class="bc-amount">₹<%= (parseFloat(structure.basic_salary||0) + parseFloat(structure.hra||0) + parseFloat(structure.other_allowances||0)).toLocaleString('en-IN',{minimumFractionDigits:2}) %></div>
        <div class="bc-period">Effective for current pay period</div>
      </div>

      <div class="breakdown-rows">
        <div class="breakdown-row">
          <div>
            <div class="br-label">Basic Salary</div>
            <div class="br-pct">50% of Base Wage</div>
          </div>
          <span class="br-amt">₹<%= parseFloat(structure.basic_salary||0).toLocaleString('en-IN',{minimumFractionDigits:2}) %></span>
        </div>
        <div class="breakdown-row">
          <div>
            <div class="br-label">House Rent Allowance</div>
            <div class="br-pct">50% of Basic (25% of Base)</div>
          </div>
          <span class="br-amt">₹<%= parseFloat(structure.hra||0).toLocaleString('en-IN',{minimumFractionDigits:2}) %></span>
        </div>
        <div class="breakdown-row">
          <div>
            <div class="br-label">Other Allowances</div>
            <div class="br-pct">Custom approved allowance</div>
          </div>
          <span class="br-amt">₹<%= parseFloat(structure.other_allowances||0).toLocaleString('en-IN',{minimumFractionDigits:2}) %></span>
        </div>
      </div>

      <div class="breakdown-total">
        <div>
          <div class="bt-label">Total Net Take-Home</div>
          <div style="font-size:0.75rem; color:var(--text-secondary); margin-top:2px;">Base Wage: ₹<%= parseFloat(structure.base_wage||0).toLocaleString('en-IN',{minimumFractionDigits:2}) %></div>
        </div>
        <span class="bt-amount">₹<%= (parseFloat(structure.basic_salary||0) + parseFloat(structure.hra||0) + parseFloat(structure.other_allowances||0)).toLocaleString('en-IN',{minimumFractionDigits:2}) %></span>
      </div>
    </div>

    <!-- Right: Payslip history -->
    <div class="payslip-history-card">
      <div class="payslip-history-header">
        <span class="material-symbols-outlined">receipt_long</span>
        <h3>My Monthly Payslips</h3>
      </div>

      <% if (payslips && payslips.length > 0) { %>
      <div style="overflow-x:auto;">
        <table style="width:100%; border-collapse:collapse; text-align:left;">
          <thead>
            <tr>
              <th style="padding:0.85rem 1.25rem; border-bottom:1px solid var(--border-color); font-size:0.75rem; text-transform:uppercase; letter-spacing:0.05em; color:var(--text-secondary); background:var(--bg-secondary);">Period</th>
              <th style="padding:0.85rem 1.25rem; border-bottom:1px solid var(--border-color); font-size:0.75rem; text-transform:uppercase; letter-spacing:0.05em; color:var(--text-secondary); background:var(--bg-secondary);">Base Wage</th>
              <th style="padding:0.85rem 1.25rem; border-bottom:1px solid var(--border-color); font-size:0.75rem; text-transform:uppercase; letter-spacing:0.05em; color:var(--text-secondary); background:var(--bg-secondary);">Deductions</th>
              <th style="padding:0.85rem 1.25rem; border-bottom:1px solid var(--border-color); font-size:0.75rem; text-transform:uppercase; letter-spacing:0.05em; color:var(--text-secondary); background:var(--bg-secondary);">Net Paid</th>
              <th style="padding:0.85rem 1.25rem; border-bottom:1px solid var(--border-color); font-size:0.75rem; text-transform:uppercase; letter-spacing:0.05em; color:var(--text-secondary); background:var(--bg-secondary);">Issued</th>
              <th style="padding:0.85rem 1.25rem; border-bottom:1px solid var(--border-color); font-size:0.75rem; text-transform:uppercase; letter-spacing:0.05em; color:var(--text-secondary); background:var(--bg-secondary);">Action</th>
            </tr>
          </thead>
          <tbody>
            <% payslips.forEach(ps => { %>
            <tr style="transition: background 0.15s;">
              <td style="padding:0.9rem 1.25rem; border-bottom:1px solid var(--border-color);">
                <span class="period-badge"><%= ps.pay_period %></span>
              </td>
              <td style="padding:0.9rem 1.25rem; border-bottom:1px solid var(--border-color); color:var(--text-secondary);">₹<%= parseFloat(ps.base_wage).toLocaleString('en-IN',{minimumFractionDigits:2}) %></td>
              <td style="padding:0.9rem 1.25rem; border-bottom:1px solid var(--border-color); color:var(--danger); font-weight:500;">
                -₹<%= parseFloat(ps.deductions || 0).toLocaleString('en-IN',{minimumFractionDigits:2}) %>
              </td>
              <td style="padding:0.9rem 1.25rem; border-bottom:1px solid var(--border-color);">
                <span class="payslip-row-net">₹<%= parseFloat(ps.net_salary).toLocaleString('en-IN',{minimumFractionDigits:2}) %></span>
              </td>
              <td style="padding:0.9rem 1.25rem; border-bottom:1px solid var(--border-color); font-size:0.82rem; color:var(--text-light);">
                <%= new Date(ps.created_at).toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' }) %>
              </td>
              <td style="padding:0.9rem 1.25rem; border-bottom:1px solid var(--border-color);">
                <a href="/payroll/payslip/<%= ps.id %>" class="btn-view-slip">
                  <span class="material-symbols-outlined" style="font-size:15px;">receipt</span> View
                </a>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="empty-state">
        <span class="material-symbols-outlined">receipt_long</span>
        <p>No payslips generated yet.</p>
      </div>
    <% } %>
    </div>
  </div>
<% } %>

<%- include('../layouts/footer') %>
