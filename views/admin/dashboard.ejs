<%- include('../layouts/header') %>

<%
  // Format payroll total for display
  const payrollDisplay = '₹' + (stats.payrollTotal || 0).toLocaleString('en-IN', { maximumFractionDigits: 0 });
%>

<!-- ── Page hero ────────────────────────────────────────── -->
<div class="page-hero">
  <h1>Admin Dashboard</h1>
  <p style="margin:0; font-size:0.85rem;">Org-wide overview — attendance, leave & payroll health.</p>
</div>

<!-- ── Action Strip (compact FAB row) ───────────────────── -->
<div class="action-strip">
  <a href="/hr/dashboard" class="action-chip">
    <span class="material-symbols-outlined">person_add</span>
    Onboard Employee
  </a>
  <a href="/payroll/dashboard" class="action-chip">
    <span class="material-symbols-outlined">edit_note</span>
    Manage Salaries
  </a>
  <a href="/attendance/admin-review" class="action-chip <% if (stats.pendingLeaves > 0) { %>action-chip--danger<% } %>">
    <span class="material-symbols-outlined">rule</span>
    Review Leaves<% if (stats.pendingLeaves > 0) { %>&nbsp;<strong>(<%= stats.pendingLeaves %>)</strong><% } %>
  </a>
</div>

<!-- ── Stat cards ───────────────────────────────────────── -->
<div class="stat-strip">
  <div class="stat-card">
    <span class="material-symbols-outlined stat-icon">groups</span>
    <span class="stat-value"><%= stats.totalEmployees %></span>
    <span class="stat-label">Total Employees</span>
  </div>

  <div class="stat-card">
    <span class="material-symbols-outlined stat-icon" style="color: var(--secondary);">flight_takeoff</span>
    <span class="stat-value"><%= stats.onLeaveToday %></span>
    <span class="stat-label">On Leave Today</span>
  </div>

  <div class="stat-card">
    <span class="material-symbols-outlined stat-icon" style="color: var(--danger);">pending_actions</span>
    <span class="stat-value"><%= stats.pendingLeaves %></span>
    <span class="stat-label">Pending Requests</span>
    <% if (stats.pendingLeaves > 0) { %>
      <a href="/attendance/admin-review" class="stat-sub" style="color:var(--danger);text-decoration:none;font-weight:600;">Review now →</a>
    <% } %>
  </div>

  <div class="stat-card">
    <span class="material-symbols-outlined stat-icon" style="color: var(--accent);">payments</span>
    <span class="stat-value stat-value--small"><%= payrollDisplay %></span>
    <span class="stat-label">Payroll This Month</span>
  </div>
</div>

<!-- ── Charts grid ──────────────────────────────────────── -->
<div class="dashboard-grid">
  <div class="chart-card">
    <div class="chart-header">
      <span class="material-symbols-outlined">show_chart</span>
      <h3>Attendance Trend (6 months)</h3>
    </div>
    <div id="attendance-trend-chart" style="min-height:260px;"></div>
  </div>

  <div class="chart-card">
    <div class="chart-header">
      <span class="material-symbols-outlined">donut_large</span>
      <h3>Leave Distribution</h3>
    </div>
    <div id="leave-distribution-chart" style="min-height:260px;"></div>
  </div>
</div>

<!-- ── Recent leave requests ────────────────────────────── -->
<div class="card">
  <div class="chart-header" style="border:none; margin-bottom:0.85rem;">
    <span class="material-symbols-outlined">inbox</span>
    <h3 style="margin:0;">Latest Pending Leave Requests</h3>
  </div>
  <% if (recentLeaves && recentLeaves.length > 0) { %>
    <div class="table-container" style="margin-bottom:0;">
      <table>
        <thead>
          <tr>
            <th>Employee</th>
            <th>Type</th>
            <th>Dates</th>
            <th>Reason</th>
          </tr>
        </thead>
        <tbody>
          <% recentLeaves.forEach(l => { %>
            <tr>
              <td>
                <strong><%= l.first_name %> <%= l.last_name %></strong>
                <div style="font-size:0.72rem;color:var(--text-light);"><%= l.login_id %></div>
              </td>
              <td><strong><%= l.leave_type %></strong></td>
              <td style="font-size:0.82rem;white-space:nowrap;">
                <%= new Date(l.start_date).toLocaleDateString() %> – <%= new Date(l.end_date).toLocaleDateString() %>
              </td>
              <td style="font-size:0.82rem;color:var(--text-secondary);max-width:280px;white-space:normal;word-break:break-word;">
                <%= l.reason %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } else { %>
    <div class="empty-state">
      <div class="empty-icon">
        <span class="material-symbols-outlined">check_circle</span>
      </div>
      <div class="empty-title">All caught up!</div>
      <p class="empty-desc">There are no pending leave requests right now.</p>
    </div>
  <% } %>
</div>

<!-- ── ApexCharts init ──────────────────────────────────── -->
<script>
  document.addEventListener('DOMContentLoaded', function () {
    if (typeof ApexCharts === 'undefined') {
      console.warn('ApexCharts not loaded — charts skipped.');
      return;
    }

    const root        = getComputedStyle(document.documentElement);
    const primary     = root.getPropertyValue('--primary').trim();
    const accent      = root.getPropertyValue('--accent').trim();
    const danger      = root.getPropertyValue('--danger').trim();
    const secondary   = root.getPropertyValue('--secondary').trim();
    const textSecondary = root.getPropertyValue('--text-secondary').trim();
    const textLight   = root.getPropertyValue('--text-light').trim();
    const borderColor = root.getPropertyValue('--border-color').trim();

    const trendData = <%- JSON.stringify(attendanceTrend || []) %>;
    const distData  = <%- JSON.stringify(leaveDistribution || { paid: 0, sick: 0, unpaid: 0 }) %>;

    // ── Attendance trend (area line) ──────────────────────
    const trendEl = document.getElementById('attendance-trend-chart');
    if (trendEl) {
      new ApexCharts(trendEl, {
        chart: {
          type: 'area',
          height: 260,
          toolbar: { show: false },
          fontFamily: 'Outfit, sans-serif',
          animations: { enabled: true, speed: 600, animateGradually: { enabled: true, delay: 80 } }
        },
        series: [
          { name: 'Present', data: trendData.map(r => parseInt(r.present, 10) || 0) },
          { name: 'Absent',  data: trendData.map(r => parseInt(r.absent,  10) || 0) },
          { name: 'Leave',   data: trendData.map(r => parseInt(r.leave,   10) || 0) }
        ],
        colors: [accent, danger, primary],
        fill: {
          type: 'gradient',
          gradient: { opacityFrom: 0.3, opacityTo: 0.05, shadeIntensity: 0 }
        },
        stroke: { width: 2.5, curve: 'smooth' },
        markers: { size: 3.5, strokeWidth: 2, hover: { size: 5 } },
        xaxis: {
          categories: trendData.map(r => r.month),
          labels: { style: { colors: textLight, fontSize: '11px' } },
          axisBorder: { color: borderColor },
          axisTicks:  { color: borderColor }
        },
        yaxis: { labels: { style: { colors: textLight, fontSize: '11px' } } },
        grid: { borderColor: borderColor, strokeDashArray: 4, padding: { left: 0, right: 0 } },
        legend: { position: 'top', horizontalAlign: 'right', labels: { colors: textSecondary }, fontSize: '12px' },
        tooltip: { theme: 'light' }
      }).render();
    }

    // ── Leave distribution (doughnut) ─────────────────────
    const distEl = document.getElementById('leave-distribution-chart');
    if (distEl) {
      const paid   = distData.paid   || 0;
      const sick   = distData.sick   || 0;
      const unpaid = distData.unpaid || 0;
      const total  = paid + sick + unpaid;

      new ApexCharts(distEl, {
        chart: { type: 'donut', height: 260, fontFamily: 'Outfit, sans-serif' },
        series: total > 0 ? [paid, sick, unpaid] : [1],
        labels:  total > 0 ? ['Paid', 'Sick', 'Unpaid'] : ['No data'],
        colors:  total > 0 ? [accent, secondary, primary] : [borderColor],
        legend: { position: 'bottom', labels: { colors: textSecondary }, fontSize: '12px' },
        dataLabels: { style: { fontSize: '12px', fontWeight: 600 } },
        plotOptions: {
          pie: {
            donut: {
              size: '65%',
              labels: {
                show: true,
                total: {
                  show: true,
                  label: total > 0 ? 'Total' : 'No leaves',
                  color: textSecondary,
                  fontSize: '13px',
                  fontWeight: 600
                }
              }
            }
          }
        },
        tooltip: { y: { formatter: v => v + ' request' + (v === 1 ? '' : 's') } }
      }).render();
    }
  });
</script>

<%- include('../layouts/footer') %>
