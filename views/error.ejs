<%- include('layouts/header') %>

<div class="card" style="max-width: 600px; margin: 4rem auto; text-align: center; padding: 3rem;">
  <span class="material-symbols-outlined" style="font-size: 64px; color: var(--danger); margin-bottom: 1.5rem;">
    gpp_maybe
  </span>
  <h1 style="color: var(--danger); font-size: 1.75rem; margin-bottom: 1rem;">An Error Occurred</h1>
  <p style="font-size: 1.1rem; color: var(--text-secondary); margin-bottom: 2rem;">
    <%= typeof message !== 'undefined' ? message : 'The page you are trying to access has encountered an error or you do not have permission.' %>
  </p>
  <a href="/" class="btn btn-primary">Go to Dashboard</a>
</div>

<%- include('layouts/footer') %>
